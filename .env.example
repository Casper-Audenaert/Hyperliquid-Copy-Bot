# Hyperliquid API
HYPERLIQUID_API_URL=https://api.hyperliquid.xyz

# Wallets to monitor on first start (can also be added via the dashboard UI)
# TARGET_WALLETS=0xabc...,0xdef...
# WALLET_LABELS=Trader A,Trader B
TARGET_WALLET_ADDRESS=0x...

# Simulation settings
SIMULATED_TRADING=true
SIMULATED_ACCOUNT_BALANCE=10000   # starting balance per wallet ($)

# Copy rules
COPY_OPEN_POSITIONS=true
COPY_EXISTING_ORDERS=true
AUTO_ADJUST_SIZE=true
USE_LIMIT_ORDERS=false
LEVERAGE_ADJUSTMENT=1.0           # 0.5 = half target leverage, 1.0 = match exactly

# Risk limits (x = unlimited)
MAX_OPEN_TRADES=x
MAX_OPEN_ORDERS=x
MAX_ACCOUNT_EQUITY=x

# Asset blocklist (comma-separated, e.g. BTC,ETH)
BLOCKED_ASSETS=

# Database + Logging
DATABASE_URL=sqlite:///./data/trading.db
LOG_LEVEL=INFO
LOG_FILE=./logs/trading.log
